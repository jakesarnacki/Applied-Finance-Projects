function onOpen() {
  SpreadsheetApp.getUi()
    .createMenu("Pokémon Tracker")
    .addItem("1) Initial setup / re-import Buneary + Lopunny", "SETUP_BUNEARY_LOPUNNY_TRACKER")
    .addItem("2) Refresh prices now", "REFRESH_PRICES")
    .addItem("3) Clear API cache", "CLEAR_PTCG_CACHE")
    .addToUi();
}

/**
 * Main setup function.
 * Run this once after pasting the script.
 */
function SETUP_BUNEARY_LOPUNNY_TRACKER() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  const settings = resetSheet_(ss, SHEET_NAMES.SETTINGS);
  const master = resetSheet_(ss, SHEET_NAMES.MASTER);
  const dashboard = resetSheet_(ss, SHEET_NAMES.DASHBOARD);
  const readme = resetSheet_(ss, SHEET_NAMES.README);

  buildSettings_(settings);
  buildMaster_(master);
  buildDashboard_(dashboard);
  buildReadMe_(readme);

  importBunearyLopunny_(master);
  applyMasterFormatting_(master);
  applyMasterValidations_(master);

  settings.getRange("B5").setValue(new Date());
  settings.getRange("B6").setValue(new Date());

  SpreadsheetApp.getUi().alert("Setup complete. Your Buneary + Lopunny tracker is ready.");
}

/**
 * Imports all Buneary + Lopunny cards from the Pokémon TCG API.
 */
function importBunearyLopunny_(master) {
  const cardsById = new Map();

  const bunearyCards = fetchCardsByPokedex_(427);
  const lopunnyCards = fetchCardsByPokedex_(428);

  bunearyCards.concat(lopunnyCards).forEach(card => {
    if (card && card.id) {
      cardsById.set(card.id, card);
    }
  });

  const cards = Array.from(cardsById.values()).sort((a, b) => {
    const dateA = ((a.set || {}).releaseDate || "");
    const dateB = ((b.set || {}).releaseDate || "");
    const setCompare = dateA.localeCompare(dateB);
    if (setCompare !== 0) return setCompare;

    const numA = Number(a.number) || 9999;
    const numB = Number(b.number) || 9999;
    return numA - numB;
  });

  const rows = [];

  cards.forEach(card => {
    const dexNums = card.nationalPokedexNumbers || [];
    const hasBuneary = dexNums.includes(427);
    const hasLopunny = dexNums.includes(428);

    let species = "";
    let pokedexNo = "";

    if (hasBuneary && hasLopunny) {
      species = "Buneary + Lopunny";
      pokedexNo = "427, 428";
    } else if (hasBuneary) {
      species = "Buneary";
      pokedexNo = "427";
    } else if (hasLopunny) {
      species = "Lopunny";
      pokedexNo = "428";
    } else {
      species = "Other";
      pokedexNo = dexNums.join(", ");
    }

    const variants = getPriceVariants_(card);

    variants.forEach(variant => {
      const priceMetric = variant === "manual" ? "manual" : "market";

      const priceObj = (((card.tcgplayer || {}).prices || {})[variant] || {});
      const marketPriceUsd = priceMetric === "manual" ? "" : cleanPrice_(priceObj[priceMetric]);

      const updatedAt = ((card.tcgplayer || {}).updatedAt || "");
      const tcgplayerUrl = ((card.tcgplayer || {}).url || "");
      const imageUrl = ((card.images || {}).large || "");

      rows.push([
        species,
        pokedexNo,
        card.id || "",
        card.name || "",
        (card.set || {}).id || "",
        (card.set || {}).name || "",
        (card.set || {}).series || "",
        (card.set || {}).releaseDate || "",
        card.number || "",
        card.rarity || "",
        variant,
        priceMetric,
        marketPriceUsd,
        "",
        "",
        false,
        0,
        "",
        "",
        "",
        "",
        "",
        updatedAt,
        tcgplayerUrl ? `=HYPERLINK("${escapeFormulaString_(tcgplayerUrl)}","TCGplayer")` : "",
        imageUrl,
        false,
        "Medium",
        "",
        ""
      ]);
    });
  });

  if (rows.length > 0) {
    master.getRange(2, 1, rows.length, MASTER_HEADERS.length).setValues(rows);
    applyLinkFormulas_(master, rows);
    applyRowFormulas_(master, rows.length);
  }
}

/**
 * Fetches cards by National Pokédex number.
 */
function fetchCardsByPokedex_(dexNo) {
  const allCards = [];
  let page = 1;
  const pageSize = 250;

  while (true) {
    const query = "nationalPokedexNumbers:" + dexNo;

    const url =
      PTCG_BASE_URL +
      "/cards?q=" +
      encodeURIComponent(query) +
      "&orderBy=set.releaseDate,number" +
      "&pageSize=" +
      pageSize +
      "&page=" +
      page;

    const json = fetchJson_(url);
    const data = json.data || [];

    allCards.push(...data);

    if (data.length < pageSize || allCards.length >= (json.totalCount || 0)) {
      break;
    }

    page++;
  }

  return allCards;
}

/**
 * Determines which TCGplayer price variants exist for a card.
 */
function getPriceVariants_(card) {
  const prices = (((card || {}).tcgplayer || {}).prices || {});
  const found = [];

  PRICE_VARIANT_ORDER.forEach(variant => {
    if (Object.prototype.hasOwnProperty.call(prices, variant)) {
      found.push(variant);
    }
  });

  Object.keys(prices).forEach(variant => {
    if (!found.includes(variant)) {
      found.push(variant);
    }
  });

  return found.length > 0 ? found : ["manual"];
}

/**
 * Refreshes prices using only a few API calls.
 * This avoids the old 429 throttling problem from fetching every card one by one.
 */
function REFRESH_PRICES(showAlert = true) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const master = ss.getSheetByName(SHEET_NAMES.MASTER);
  const settings = ss.getSheetByName(SHEET_NAMES.SETTINGS);

  if (!master) {
    throw new Error("Master Tracker sheet not found. Run setup first.");
  }

  const lastRow = master.getLastRow();

  if (lastRow < 2) {
    if (showAlert) SpreadsheetApp.getUi().alert("No cards found to refresh.");
    return;
  }

  const numRows = lastRow - 1;
  const values = master.getRange(2, 1, numRows, MASTER_HEADERS.length).getValues();

  const allCards = fetchCardsByPokedex_(427).concat(fetchCardsByPokedex_(428));
  const cardMap = {};

  allCards.forEach(card => {
    if (card && card.id) {
      cardMap[card.id] = card;
    }
  });

  const priceValues = [];
  const updatedValues = [];
  const linkFormulas = [];

  values.forEach(row => {
    const cardId = String(row[2] || "").trim();        // Column C
    const variant = String(row[10] || "").trim();      // Column K
    const metric = String(row[11] || "market").trim(); // Column L

    const card = cardMap[cardId];

    let price = "";
    let updatedAt = "";
    let tcgplayerUrl = "";

    if (metric === "manual") {
      priceValues.push([row[12] || ""]);
      updatedValues.push([row[22] || ""]);
      linkFormulas.push([row[23] || ""]);
      return;
    }

    if (card && card.tcgplayer) {
      updatedAt = card.tcgplayer.updatedAt || "";
      tcgplayerUrl = card.tcgplayer.url || "";

      const priceObj = (((card.tcgplayer || {}).prices || {})[variant] || {});
      price = cleanPrice_(priceObj[metric]);
    }

    priceValues.push([price]);
    updatedValues.push([updatedAt]);

    if (tcgplayerUrl) {
      linkFormulas.push([`=HYPERLINK("${escapeFormulaString_(tcgplayerUrl)}","TCGplayer")`]);
    } else {
      linkFormulas.push([""]);
    }
  });

  master.getRange(2, 13, numRows, 1).setValues(priceValues);    // M
  master.getRange(2, 23, numRows, 1).setValues(updatedValues);  // W
  master.getRange(2, 24, numRows, 1).setFormulas(linkFormulas); // X

  if (settings) {
    settings.getRange("B6").setValue(new Date());
  }

  if (showAlert) {
    SpreadsheetApp.getUi().alert("Prices refreshed successfully.");
  }
}

/**
 * Optional custom function:
 * =PTCG_PRICE("swsh4-25","reverseHolofoil","market")
 */
function PTCG_PRICE(cardId, variant, metric) {
  if (!cardId) return "";

  const card = getPtcgCardById_(String(cardId).trim());
  const prices = (((card || {}).tcgplayer || {}).prices || {});
  const selectedVariant = prices[variant || "normal"];

  if (!selectedVariant) return "";

  const value = selectedVariant[metric || "market"];
  return cleanPrice_(value);
}

/**
 * Optional custom function:
 * =PTCG_UPDATED("swsh4-25")
 */
function PTCG_UPDATED(cardId) {
  if (!cardId) return "";

  const card = getPtcgCardById_(String(cardId).trim());
  return ((card || {}).tcgplayer || {}).updatedAt || "";
}

/**
 * Optional custom function:
 * =PTCG_URL("swsh4-25")
 */
function PTCG_URL(cardId) {
  if (!cardId) return "";

  const card = getPtcgCardById_(String(cardId).trim());
  return ((card || {}).tcgplayer || {}).url || "";
}

/**
 * Gets one card by ID from cache/API.
 */
function getPtcgCardById_(cardId) {
  const cleanId = String(cardId || "").trim();
  if (!cleanId) return null;

  const cache = CacheService.getScriptCache();
  const cacheKey = "ptcg_card_" + cleanId;
  const cached = cache.get(cacheKey);

  if (cached) {
    return JSON.parse(cached);
  }

  const url = PTCG_BASE_URL + "/cards/" + encodeURIComponent(cleanId);
  const json = fetchJson_(url);
  const card = json.data || null;

  if (card) {
    cache.put(cacheKey, JSON.stringify(card), 21600); // 6 hours
  }

  return card;
}

/**
 * Fetches JSON with retry handling for 429 throttling.
 */
function fetchJson_(url) {
  const options = {
    method: "get",
    muteHttpExceptions: true,
    headers: {}
  };

  const apiKey = getApiKey_();

  if (apiKey) {
    options.headers["X-Api-Key"] = apiKey;
  }

  const maxAttempts = 4;

  for (let attempt = 1; attempt <= maxAttempts; attempt++) {
    const response = UrlFetchApp.fetch(url, options);
    const code = response.getResponseCode();
    const text = response.getContentText();

    if (code >= 200 && code < 300) {
      return JSON.parse(text);
    }

    if (code === 429 && attempt < maxAttempts) {
      Utilities.sleep(65000);
      continue;
    }

    throw new Error("Pokémon TCG API error " + code + ": " + text);
  }

  throw new Error("Failed to fetch API data.");
}

/**
 * Reads optional API key from Settings!B4.
 */
function getApiKey_() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const settings = ss.getSheetByName(SHEET_NAMES.SETTINGS);

  if (!settings) return "";

  return String(settings.getRange("B4").getValue() || "").trim();
}

/**
 * Clears cached card data.
 */
function CLEAR_PTCG_CACHE() {
  const cache = CacheService.getScriptCache();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const master = ss.getSheetByName(SHEET_NAMES.MASTER);

  if (!master || master.getLastRow() < 2) {
    SpreadsheetApp.getUi().alert("No card cache to clear.");
    return;
  }

  const ids = master
    .getRange(2, 3, master.getLastRow() - 1, 1)
    .getValues()
    .flat()
    .map(id => String(id || "").trim())
    .filter(id => id !== "");

  const keys = Array.from(new Set(ids)).map(id => "ptcg_card_" + id);

  if (keys.length > 0) {
    cache.removeAll(keys);
  }

  SpreadsheetApp.getUi().alert("API cache cleared.");
}

/**
 * Creates or clears a sheet.
 */
function resetSheet_(ss, name) {
  let sheet = ss.getSheetByName(name);

  if (!sheet) {
    sheet = ss.insertSheet(name);
  }

  const filter = sheet.getFilter();
  if (filter) filter.remove();

  sheet.clear();
  sheet.clearConditionalFormatRules();

  return sheet;
}

