/**
 * Builds Master Tracker sheet.
 */
function buildMaster_(sheet) {
  sheet.getRange(1, 1, 1, MASTER_HEADERS.length).setValues([MASTER_HEADERS]);

  sheet.setFrozenRows(1);
  sheet.getRange(1, 1, 1, MASTER_HEADERS.length)
    .setFontWeight("bold")
    .setBackground("#eeeeee");

  const widths = [
    150, 110, 130, 220, 100, 220, 160, 110, 90, 160,
    150, 120, 130, 110, 130, 90, 90, 110, 140, 130,
    140, 130, 140, 130, 320, 130, 140, 160, 260
  ];

  widths.forEach((width, i) => {
    sheet.setColumnWidth(i + 1, width);
  });
}

/**
 * Applies row formulas.
 */
function applyRowFormulas_(sheet, numRows) {
  if (numRows <= 0) return;

  const fxFormulas = [];
  const audPriceFormulas = [];
  const totalCostFormulas = [];
  const marketValueFormulas = [];
  const gainLossFormulas = [];

  for (let i = 0; i < numRows; i++) {
    const r = i + 2;

    fxFormulas.push([`=Settings!$B$2`]);
    audPriceFormulas.push([`=IFERROR($M${r}*$N${r},"")`]);
    totalCostFormulas.push([`=IFERROR($Q${r}*$S${r},0)`]);
    marketValueFormulas.push([`=IFERROR($Q${r}*$O${r},0)`]);
    gainLossFormulas.push([`=IFERROR($U${r}-$T${r},0)`]);
  }

  sheet.getRange(2, 14, numRows, 1).setFormulas(fxFormulas);          // N
  sheet.getRange(2, 15, numRows, 1).setFormulas(audPriceFormulas);    // O
  sheet.getRange(2, 20, numRows, 1).setFormulas(totalCostFormulas);   // T
  sheet.getRange(2, 21, numRows, 1).setFormulas(marketValueFormulas); // U
  sheet.getRange(2, 22, numRows, 1).setFormulas(gainLossFormulas);    // V
}

/**
 * Re-applies hyperlink formulas to TCGplayer column after setValues.
 */
function applyLinkFormulas_(sheet, rows) {
  const formulas = rows.map(row => {
    const value = row[23];

    if (typeof value === "string" && value.startsWith("=HYPERLINK")) {
      return [value];
    }

    return [""];
  });

  if (formulas.length > 0) {
    sheet.getRange(2, 24, formulas.length, 1).setFormulas(formulas);
  }
}

/**
 * Formatting.
 */
function applyMasterFormatting_(sheet) {
  const lastRow = Math.max(sheet.getLastRow(), 2);

  sheet.getRange(2, 13, lastRow - 1, 3).setNumberFormat("$#,##0.00"); // M:O
  sheet.getRange(2, 19, lastRow - 1, 4).setNumberFormat("$#,##0.00"); // S:V
  sheet.getRange(2, 14, lastRow - 1, 1).setNumberFormat("0.0000");    // N
  sheet.getRange(2, 23, lastRow - 1, 1).setNumberFormat("yyyy/mm/dd");

  if (lastRow > 1 && !sheet.getFilter()) {
    sheet.getRange(1, 1, lastRow, MASTER_HEADERS.length).createFilter();
  }

  const rules = [];

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=$P2=TRUE")
      .setBackground("#d9ead3")
      .setRanges([sheet.getRange(2, 1, lastRow - 1, MASTER_HEADERS.length)])
      .build()
  );

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenFormulaSatisfied("=$P2=FALSE")
      .setBackground("#fce5cd")
      .setRanges([sheet.getRange(2, 1, lastRow - 1, MASTER_HEADERS.length)])
      .build()
  );

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenNumberGreaterThan(0)
      .setBackground("#d9ead3")
      .setRanges([sheet.getRange(2, 22, lastRow - 1, 1)])
      .build()
  );

  rules.push(
    SpreadsheetApp.newConditionalFormatRule()
      .whenNumberLessThan(0)
      .setBackground("#f4cccc")
      .setRanges([sheet.getRange(2, 22, lastRow - 1, 1)])
      .build()
  );

  sheet.setConditionalFormatRules(rules);
}

/**
 * Dropdowns and checkboxes.
 */
function applyMasterValidations_(sheet) {
  const maxRows = sheet.getMaxRows();
  const editableRows = maxRows - 1;

  if (editableRows <= 0) return;

  const variantRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(PRICE_VARIANT_ORDER.concat(["manual"]), true)
    .setAllowInvalid(true)
    .build();

  const metricRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(PRICE_METRICS, true)
    .setAllowInvalid(true)
    .build();

  const conditionRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(["NM", "LP", "MP", "HP", "DM", "Graded", "Sealed", "Unknown"], true)
    .setAllowInvalid(true)
    .build();

  const priorityRule = SpreadsheetApp.newDataValidation()
    .requireValueInList(["Low", "Medium", "High", "Chase"], true)
    .setAllowInvalid(true)
    .build();

  sheet.getRange(2, 11, editableRows, 1).setDataValidation(variantRule);   // K
  sheet.getRange(2, 12, editableRows, 1).setDataValidation(metricRule);    // L
  sheet.getRange(2, 18, editableRows, 1).setDataValidation(conditionRule); // R
  sheet.getRange(2, 27, editableRows, 1).setDataValidation(priorityRule);  // AA

  sheet.getRange(2, 16, editableRows, 1).insertCheckboxes(); // P
  sheet.getRange(2, 26, editableRows, 1).insertCheckboxes(); // Z
}

